{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      },
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "string"
    },
    "accessLevel": {
      "type": "enumeration",
      "required": true,
      "default": "public",
      "enum": [
        "public",
        "authenticated",
        "restricted"
      ]
    },
    "allowedUsers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "allowedGroups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::access-group.access-group",
      "inversedBy": "pages"
    }
  }
}
