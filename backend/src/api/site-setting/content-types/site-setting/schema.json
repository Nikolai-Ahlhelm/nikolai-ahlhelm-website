{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Setting"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "default": "My Site",
      "required": true
    },
    "defaultTheme": {
      "type": "enumeration",
      "required": true,
      "default": "system",
      "enum": [
        "system",
        "light",
        "dark"
      ]
    },
    "defaultPage": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::page.page"
    },
    "backgroundMode": {
      "type": "enumeration",
      "required": true,
      "default": "image",
      "enum": [
        "default",
        "image",
        "shader"
      ]
    },
    "backgroundImageLight": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "backgroundImageDark": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "backgroundOverlayColorLight": {
      "type": "customField",
      "customField": "plugin::advanced-fields.color"
    },
    "backgroundOverlayColorDark": {
      "type": "customField",
      "customField": "plugin::advanced-fields.color"
    },
    "backgroundOverlayTransparencyLight": {
      "type": "decimal",
      "default": 0.35,
      "min": 0,
      "max": 1
    },
    "backgroundOverlayTransparencyDark": {
      "type": "decimal",
      "default": 0.25,
      "min": 0,
      "max": 1
    }
  }
}
