{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Setting"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "default": "My Site",
      "required": true
    },
    "defaultTheme": {
      "type": "enumeration",
      "required": true,
      "default": "system",
      "enum": [
        "system",
        "light",
        "dark"
      ]
    },
    "defaultPage": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::page.page"
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
